locals {
  pihole_macs = [
    "BC:24:11:10:00:05",
    "BC:24:11:10:00:06",  
  ]
}

module "pihole-servers" {
  source   = "./modules/ubuntu2404_vm"
  count = 2
  clone_id = 9910

  # Properties for new VM
  vmid               = 1005 + count.index
  name               = "pihole-0${count.index + 1}"
  target_node        = var.proxmox_nodes[count.index]
  tags               = "infrastructure,pihole,dns"
  start_at_node_boot = true

  # --- Hardware Resources ---
  memory    = 2048
  cores     = 1
  disk_size = "32G"

  # Network configuration
  bridge      = "vmbr0"
  ip_address  = "10.0.10.${count.index + 5}"
  mac_address = local.pihole_macs[count.index]
  gateway     = "10.0.10.1"
  nameserver  = "10.0.10.1"

  # Cloud-init and SSH configuration
  searchdomain = var.searchdomain
  ci_user      = var.ci_user
  ci_password  = var.ci_password
  ssh_keys     = var.ssh_keys

  # High Availability configuration
  ha_state      = "started"
  ha_group_name = "critical-infra"

  # Backup configuration
  pool = "Bronze-Systems"
}
